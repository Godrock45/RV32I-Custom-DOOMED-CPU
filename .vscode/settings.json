{
  "emeraldwalk.runonsave": {
    "shell": "powershell.exe",
    "commands": [
      {
        "match": "\\.(sv|txt)$",
        "isAsync": true,
        "cmd": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}/.vscode/auto-commit.ps1\" -SavedFile \"${file}\"",
        "message": "Auto-committing ${fileBasename}..."
      }
    ]
  }
}
